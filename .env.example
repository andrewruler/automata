# --- OpenAI (Responses API) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# --- Browser: real Chrome, your profile (see docs/CHROME_SETUP.md) ---
HEADLESS=false
CHROME_CHANNEL=chrome

# Windows: your real Chrome "User Data" folder (quit Chrome before launch)
# CHROME_USER_DATA_DIR=C:\Users\You\AppData\Local\Google\Chrome\User Data
# CHROME_PROFILE_DIRECTORY=Default

# Or: attach to Chrome you started with --remote-debugging-port=9222 (Chrome stays open after run)
# CHROME_CDP_URL=http://127.0.0.1:9222

# --- Demo task (src/index.ts) ---
DEMO_EMAIL=testuser@example.com
DEMO_PASSWORD=
DEMO_FULL_NAME=Test User
