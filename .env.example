# --- OpenAI (Responses API) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# --- Mission intake (Phase B starter) ---
# You can pass this at runtime instead: npm start -- "Create Render web service ..."
MISSION_GOAL=Create an account for this browser application and stop when the dashboard appears
# Comma-separated hostname allowlist (required)
ALLOWED_DOMAINS=example.com
# Dev-only escape hatch: bypass domain allowlist checks entirely
# ALLOW_ALL_DOMAINS=true
# Optional explicit start URL; defaults to https://<first allowed domain>
START_URL=https://example.com
MISSION_DEADLINE_SECONDS=300
MISSION_MAX_STEPS=40
# Optional constraints string list, comma-separated
# MISSION_CONSTRAINTS=no password resets,no third-party domains
# Phase C starter: off|every|fallback (fallback reserved, behaves like off for now)
VISION_MODE=off

# --- Coding lane scaffold (Phase J starter) ---
# Run: npm run code -- "Run checks before commit"
CODE_PROVIDER=local-shell
CODING_MISSION_GOAL=Run project coding checks
CODING_WORKDIR=.
# Comma-separated shell commands executed in order
CODING_COMMANDS=npm run build
# Optional constraints list for future providers
# CODING_CONSTRAINTS=no force push,no deleting files

# --- Browser: real Chrome, your profile (see docs/CHROME_SETUP.md) ---
HEADLESS=false
CHROME_CHANNEL=chrome

# Windows: your real Chrome "User Data" folder (quit Chrome before launch)
# CHROME_USER_DATA_DIR=C:\Users\You\AppData\Local\Google\Chrome\User Data
# CHROME_PROFILE_DIRECTORY=Default

# Or: attach to Chrome you started with --remote-debugging-port=9222 (Chrome stays open after run)
# CHROME_CDP_URL=http://127.0.0.1:9222

# --- Local credential values (sent to browser only, not to model) ---
DEMO_EMAIL=testuser@example.com
DEMO_PASSWORD=
DEMO_FULL_NAME=Test User
